{
  "info": {
    "name": "College Event & Workshop Management Portal",
    "_postman_id": "a3f0fd43-e1ef-4cd1-bccf-portal-demo",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Core API flows for authentication, events, registrations, certificates, notifications, and admin analytics."
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080/api"
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "refreshToken",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login Admin",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@collegeportal.local\",\n  \"password\": \"Admin@123\",\n  \"rememberMe\": true\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('accessToken', json.data.accessToken);",
                  "pm.collectionVariables.set('refreshToken', json.data.refreshToken);"
                ]
              }
            }
          ]
        },
        {
          "name": "Register Student",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Demo\",\n  \"lastName\": \"Student\",\n  \"email\": \"demo.student@collegeportal.local\",\n  \"password\": \"Demo@1234\",\n  \"role\": \"STUDENT\"\n}"
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/refresh",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "refresh"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Events",
      "item": [
        {
          "name": "List Events",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/events?page=0&size=10&direction=ASC",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "events"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "0"
                },
                {
                  "key": "size",
                  "value": "10"
                },
                {
                  "key": "direction",
                  "value": "ASC"
                }
              ]
            }
          }
        },
        {
          "name": "Get Event By Id",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/events/1",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "events",
                "1"
              ]
            }
          }
        },
        {
          "name": "Create Event",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/events",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "events"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Postman Demo Workshop\",\n  \"description\": \"Created from the Postman collection.\",\n  \"categoryId\": 1,\n  \"eventType\": \"Workshop\",\n  \"startDate\": \"2026-04-10\",\n  \"endDate\": \"2026-04-10\",\n  \"startTime\": \"10:00\",\n  \"endTime\": \"13:00\",\n  \"registrationDeadline\": \"2026-04-09T18:00:00\",\n  \"maximumParticipants\": 40,\n  \"visibility\": \"PUBLIC\",\n  \"publishNow\": true,\n  \"multiDay\": false,\n  \"recurring\": false,\n  \"registrationRequiresApproval\": false,\n  \"registrationClosed\": false,\n  \"sessions\": []\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Registrations",
      "item": [
        {
          "name": "Register For Event",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/registrations/events/1",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "registrations",
                "events",
                "1"
              ]
            }
          }
        },
        {
          "name": "My Registrations",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/registrations/my",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "registrations",
                "my"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Certificates & Notifications",
      "item": [
        {
          "name": "My Certificates",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/certificates/my",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "certificates",
                "my"
              ]
            }
          }
        },
        {
          "name": "My Notifications",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/notifications/my",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "notifications",
                "my"
              ]
            }
          }
        },
        {
          "name": "Verify Certificate",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/certificates/verify/verify-embed-2026",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "certificates",
                "verify",
                "verify-embed-2026"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Admin Dashboard",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/dashboard",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "dashboard"
              ]
            }
          }
        },
        {
          "name": "Audit Logs",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/audit-logs?page=0&size=10",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "audit-logs"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "0"
                },
                {
                  "key": "size",
                  "value": "10"
                }
              ]
            }
          }
        }
      ]
    }
  ]
}